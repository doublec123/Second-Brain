{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/second-brain/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/second-brain/dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/app.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/second-brain/dist/public/$1"
    }
  ]
}
